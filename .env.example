# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Gemini AI (for Edge Functions)
GEMINI_API_KEY=your-gemini-api-key

# Paddle (payment provider)
PADDLE_API_KEY=your-paddle-api-key
PADDLE_WEBHOOK_SECRET=your-paddle-webhook-secret
PADDLE_STARTER_MONTHLY=pri_xxx
PADDLE_STARTER_YEARLY=pri_xxx
PADDLE_PROFESSIONAL_MONTHLY=pri_xxx
PADDLE_PROFESSIONAL_YEARLY=pri_xxx
PADDLE_BUSINESS_MONTHLY=pri_xxx
PADDLE_BUSINESS_YEARLY=pri_xxx

# LemonSqueezy (alternative payment provider)
LEMONSQUEEZY_API_KEY=your-ls-api-key
LS_WEBHOOK_SECRET=your-ls-webhook-secret
LS_STORE_ID=your-store-id
LS_STARTER_MONTHLY=variant_xxx
LS_STARTER_YEARLY=variant_xxx
LS_PROFESSIONAL_MONTHLY=variant_xxx
LS_PROFESSIONAL_YEARLY=variant_xxx
LS_BUSINESS_MONTHLY=variant_xxx
LS_BUSINESS_YEARLY=variant_xxx

# Google OAuth (configured in Supabase dashboard)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Supabase service key (for scrapers/upload)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
